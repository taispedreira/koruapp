<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Koru — protótipo MVP</title>
<style>
  :root{
    --creme:#F7F4EC; --card:#FFFFFF; --borda:#E3DFD2; --borda-suave:#EFEBDE;
    --verde:#1C4A35; --verde-noite:#122E22; --verde-medio:#35573F;
    --dourado:#B8963E; --dourado-claro:#D4AF5A; --bege:#F0EBE0;
    --txt:#3A3830; --txt-sec:#6B675C; --txt-muted:#8A867A; --txt-fraco:#B0AC9E;
    --salvia:#A8BFA9;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:#E9E5DA;font-family:-apple-system,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    display:flex;justify-content:center;align-items:flex-start;min-height:100vh;padding:24px 12px}
  .phone{width:100%;max-width:390px;background:var(--creme);border-radius:32px;
    box-shadow:0 20px 60px rgba(28,74,53,.18);overflow:hidden;position:relative;min-height:760px;
    display:flex;flex-direction:column}
  @media (max-width:430px){body{padding:0}.phone{border-radius:0;min-height:100vh;box-shadow:none}}
  .tela{display:none;flex-direction:column;flex:1;animation:entra .45s ease}
  .tela.ativa{display:flex}
  @keyframes entra{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
  @media (prefers-reduced-motion: reduce){.tela{animation:none}.nucleo{animation:none!important}.spin{animation:none!important}}

  .serif{font-family:Georgia,"Times New Roman",serif}
  .btn{display:block;width:100%;padding:15px;border:none;border-radius:24px;background:var(--verde);
    color:var(--bege);font-size:15px;cursor:pointer;font-family:inherit;transition:opacity .15s}
  .btn:hover{opacity:.92}
  .btn:focus-visible{outline:3px solid var(--dourado);outline-offset:2px}
  .btn-fantasma{background:transparent;color:var(--txt-sec);border:1px solid #C9C4B2}
  .btn:disabled{opacity:.4;cursor:default}

  /* ===== SPLASH ===== */
  #splash{justify-content:center;align-items:center;text-align:center;padding:40px 32px;gap:0}
  .logo-grande{width:110px;height:110px;margin-bottom:26px}
  #splash h1{font-size:44px;color:var(--verde);font-weight:400;letter-spacing:2px}
  .tagline{font-size:11px;color:var(--dourado);letter-spacing:4px;text-transform:uppercase;margin:10px 0 30px}
  .splash-frase{font-size:15px;color:var(--txt-sec);line-height:1.7;max-width:280px;margin-bottom:44px}
  #splash .btn{max-width:260px}
  .splash-nota{font-size:11px;color:var(--txt-fraco);margin-top:16px;line-height:1.5;max-width:280px}

  /* ===== HEADER DIAG ===== */
  .diag-head{padding:18px 24px 10px;display:flex;align-items:center;gap:12px}
  .diag-head .mini-logo{width:26px;height:26px;flex-shrink:0}
  .diag-passo{font-size:11px;color:var(--txt-fraco);margin-left:auto;letter-spacing:.5px}
  .prog{height:3px;background:var(--borda-suave);margin:0 24px;border-radius:2px;overflow:hidden}
  .prog-fill{height:100%;background:var(--dourado);border-radius:2px;transition:width .5s ease;width:0}

  .diag-corpo{flex:1;padding:22px 24px 24px;display:flex;flex-direction:column;overflow-y:auto}
  .diag-titulo{font-size:21px;color:var(--verde);margin-bottom:6px;line-height:1.35}
  .diag-sub{font-size:13px;color:var(--txt-muted);margin-bottom:22px;line-height:1.5}

  /* dados físicos */
  .campos{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:auto}
  .campo{background:var(--card);border:1px solid var(--borda);border-radius:12px;padding:12px 14px}
  .campo label{display:block;font-size:11px;color:var(--txt-muted);margin-bottom:4px}
  .campo input,.campo select{width:100%;border:none;background:transparent;font-size:16px;color:var(--txt);
    font-family:inherit;outline:none;-moz-appearance:textfield}
  .campo input::-webkit-outer-spin-button,.campo input::-webkit-inner-spin-button{-webkit-appearance:none}
  .opc-nota{font-size:11px;color:var(--txt-fraco);margin:14px 0 20px;line-height:1.5}

  /* conversa diagnóstica */
  .chat{display:flex;flex-direction:column;gap:12px;flex:1}
  .balao-koru{background:var(--card);border:1px solid var(--borda);border-radius:16px;
    border-bottom-left-radius:4px;padding:13px 16px;font-size:14px;color:var(--txt);
    line-height:1.6;max-width:88%;align-self:flex-start}
  .balao-eu{background:var(--verde);color:var(--bege);border-radius:16px;border-bottom-right-radius:4px;
    padding:12px 15px;font-size:14px;line-height:1.55;max-width:85%;align-self:flex-end}
  .chips{display:flex;flex-wrap:wrap;gap:8px;margin-top:2px}
  .chip{padding:9px 16px;border-radius:20px;border:1px solid #C9C4B2;background:transparent;
    font-size:13px;color:var(--txt-sec);cursor:pointer;font-family:inherit;transition:all .15s}
  .chip:hover{border-color:var(--verde)}
  .chip:focus-visible{outline:2px solid var(--dourado);outline-offset:2px}
  .chip.on{background:var(--verde);border-color:var(--verde);color:var(--bege)}
  .escreve{margin-top:auto;padding-top:14px}
  .escreve textarea{width:100%;border:1px solid var(--borda);border-radius:14px;background:var(--card);
    padding:13px 15px;font-size:14px;color:var(--txt);font-family:inherit;resize:none;outline:none;
    line-height:1.5;min-height:84px}
  .escreve textarea:focus{border-color:var(--dourado)}
  .escreve .hint{font-size:11px;color:var(--txt-fraco);margin:6px 2px 12px}

  /* gerando */
  #gerando{justify-content:center;align-items:center;text-align:center;padding:40px}
  .nucleo{width:120px;height:120px;margin-bottom:30px;animation:respira 3.2s ease-in-out infinite}
  @keyframes respira{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
  .gerando-txt{font-size:15px;color:var(--txt-sec);line-height:1.7;max-width:250px;min-height:52px}

  /* retrato */
  .retrato-wrap{flex:1;padding:26px 24px;display:flex;flex-direction:column;overflow-y:auto}
  .ret-eyebrow{font-size:10px;color:var(--txt-fraco);letter-spacing:2.5px;text-transform:uppercase;
    text-align:center;margin-bottom:14px}
  .ret-card{background:var(--card);border:1px solid var(--borda);border-radius:18px;padding:24px 22px;margin-bottom:14px}
  .ret-texto{font-size:15.5px;color:var(--txt);line-height:1.8;font-style:italic}
  .ret-texto .voce-disse{color:var(--verde);font-weight:bold}
  .ret-fonte{font-size:11px;color:var(--txt-fraco);margin-top:16px;line-height:1.5}
  .ret-aviso{font-size:12px;color:var(--txt-muted);text-align:center;line-height:1.6;margin:8px 12px 20px}
  .ret-chips{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;margin-bottom:22px}
  .ret-chip{font-size:11px;padding:5px 12px;border-radius:14px;background:var(--bege);color:var(--verde)}

  /* home */
  .home-head{padding:18px 22px 12px;display:flex;align-items:center;gap:10px}
  .home-head .nome{font-size:18px;color:var(--verde);letter-spacing:1px}
  .home-dia{font-size:11px;color:var(--txt-fraco);margin-left:auto}
  .home-chat{flex:1;padding:8px 18px;display:flex;flex-direction:column;gap:11px;overflow-y:auto}
  .proto-card{background:var(--card);border:1.5px solid #D9D4C4;border-radius:16px;padding:16px;max-width:92%}
  .proto-top{display:flex;gap:12px;align-items:center;margin-bottom:8px}
  .proto-ic{width:36px;height:36px;border-radius:50%;background:var(--bege);display:flex;
    align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
  .proto-nome{font-size:15px;color:var(--verde)}
  .proto-tempo{font-size:11px;color:var(--txt-muted)}
  .proto-desc{font-size:12.5px;color:var(--txt-sec);line-height:1.5;margin-bottom:12px}
  .proto-acoes{display:flex;gap:8px;flex-wrap:wrap}
  .proto-btn{padding:9px 16px;border-radius:18px;font-size:12.5px;cursor:pointer;border:none;font-family:inherit}
  .proto-btn.cheio{background:var(--verde);color:var(--bege)}
  .proto-btn.vazio{background:transparent;border:1px solid #C9C4B2;color:var(--txt-sec)}
  .home-input{display:flex;align-items:center;gap:10px;margin:10px 16px;background:var(--card);
    border:1px solid #D9D4C4;border-radius:24px;padding:4px 6px 4px 18px}
  .home-input input{flex:1;border:none;background:transparent;font-size:14px;color:var(--txt);
    font-family:inherit;outline:none;padding:10px 0}
  .home-input button{width:38px;height:38px;border-radius:50%;border:none;background:var(--dourado);
    color:#fff;font-size:15px;cursor:pointer;flex-shrink:0}
  .tabs{display:flex;justify-content:space-around;padding:10px 20px 22px;border-top:1px solid var(--borda)}
  .tab{display:flex;flex-direction:column;align-items:center;gap:3px;font-size:10px;color:var(--txt-fraco);
    background:none;border:none;cursor:pointer;font-family:inherit}
  .tab.on{color:var(--verde)}
  .tab span{font-size:18px}
  .demo-nota{position:absolute;top:10px;left:50%;transform:translateX(-50%);font-size:9px;
    color:var(--txt-fraco);letter-spacing:1.5px;text-transform:uppercase}
  .typing{display:inline-flex;gap:4px;padding:4px 2px}
  .typing i{width:6px;height:6px;border-radius:50%;background:var(--txt-fraco);animation:tp 1s infinite}
  .typing i:nth-child(2){animation-delay:.15s}.typing i:nth-child(3){animation-delay:.3s}
  @keyframes tp{0%,100%{opacity:.3}50%{opacity:1}}
</style>
</head>
<body>
<div class="phone">
  <div class="demo-nota">protótipo · mvp</div>

  <!-- SPLASH -->
  <section class="tela ativa" id="splash" aria-label="Boas-vindas">
    <svg class="logo-grande" viewBox="0 0 60 60" aria-hidden="true">
      <path d="M30,8 C43,8 52,18 52,30 C52,39 46,46.5 37,49 C31,50.8 25,50 20.5,47" fill="none" stroke="#1C4A35" stroke-width="2.6" stroke-linecap="round"/>
      <path d="M20.5,47 C15,43.5 12.5,37 14,31 C15.3,26 19.5,22.5 24,22.5" fill="none" stroke="#1C4A35" stroke-width="2.6" stroke-linecap="round"/>
      <path d="M24,22.5 C27,22.3 30,24.2 30.8,27.8 C31.5,30.8 29.4,33.6 26.6,33.6" fill="none" stroke="#1C4A35" stroke-width="2.6" stroke-linecap="round"/>
      <circle cx="28.5" cy="28" r="2.6" fill="#B8963E"/>
    </svg>
    <h1 class="serif">Koru</h1>
    <div class="tagline">know yourself deeply</div>
    <p class="splash-frase serif">Sem metas. Sem streaks. Sem comparação.<br>Uma conversa que aprende quem você é.</p>
    <button class="btn" onclick="ir('dados')">Começar — leva uns 5 minutos</button>
    <p class="splash-nota">O Koru não é um serviço médico e não substitui profissionais de saúde. Seus registros são seus: exportáveis e apagáveis a qualquer momento.</p>
  </section>

  <!-- DADOS FÍSICOS -->
  <section class="tela" id="dados" aria-label="Dados físicos">
    <div class="diag-head">
      <svg class="mini-logo" viewBox="0 0 60 60" aria-hidden="true"><path d="M30,8 C43,8 52,18 52,30 C52,39 46,46.5 37,49 C31,50.8 25,50 20.5,47" fill="none" stroke="#1C4A35" stroke-width="3" stroke-linecap="round"/><path d="M20.5,47 C15,43.5 12.5,37 14,31 C15.3,26 19.5,22.5 24,22.5" fill="none" stroke="#1C4A35" stroke-width="3" stroke-linecap="round"/><circle cx="28.5" cy="28" r="3" fill="#B8963E"/></svg>
      <div class="diag-passo">1 de 4</div>
    </div>
    <div class="prog"><div class="prog-fill" style="width:25%"></div></div>
    <div class="diag-corpo">
      <h2 class="diag-titulo serif">Primeiro, o básico do corpo</h2>
      <p class="diag-sub">Só o essencial — nada aqui vira meta ou cobrança.</p>
      <div class="campos">
        <div class="campo"><label for="f-nome">Como te chamar</label><input id="f-nome" type="text" placeholder="seu nome" autocomplete="given-name"></div>
        <div class="campo"><label for="f-idade">Idade</label><input id="f-idade" type="number" placeholder="—" min="18" max="110"></div>
        <div class="campo"><label for="f-peso">Peso (kg)</label><input id="f-peso" type="number" placeholder="—" min="30" max="300"></div>
        <div class="campo"><label for="f-altura">Altura (m)</label><input id="f-altura" type="number" step="0.01" placeholder="—" min="1" max="2.3"></div>
      </div>
      <p class="opc-nota">Todos os campos são opcionais. Você pode preencher depois — ou nunca.</p>
      <button class="btn" onclick="ir('sentindo')">Continuar</button>
    </div>
  </section>

  <!-- CONVERSA 1: chegada -->
  <section class="tela" id="sentindo" aria-label="Como você está chegando">
    <div class="diag-head">
      <svg class="mini-logo" viewBox="0 0 60 60" aria-hidden="true"><path d="M30,8 C43,8 52,18 52,30 C52,39 46,46.5 37,49 C31,50.8 25,50 20.5,47" fill="none" stroke="#1C4A35" stroke-width="3" stroke-linecap="round"/><path d="M20.5,47 C15,43.5 12.5,37 14,31 C15.3,26 19.5,22.5 24,22.5" fill="none" stroke="#1C4A35" stroke-width="3" stroke-linecap="round"/><circle cx="28.5" cy="28" r="3" fill="#B8963E"/></svg>
      <div class="diag-passo">2 de 4</div>
    </div>
    <div class="prog"><div class="prog-fill" style="width:50%"></div></div>
    <div class="diag-corpo">
      <div class="chat">
        <div class="balao-koru">Antes de qualquer pergunta de formulário — como você está chegando aqui hoje? Não o que quer mudar. O que está <em>sentindo</em> agora.</div>
        <div class="chips" role="group" aria-label="Como você está se sentindo">
          <button class="chip" data-grupo="estado" data-v="cansada mas esperançosa">cansada, mas esperançosa</button>
          <button class="chip" data-grupo="estado" data-v="em transição">em transição</button>
          <button class="chip" data-grupo="estado" data-v="sobrecarregada">sobrecarregada</button>
          <button class="chip" data-grupo="estado" data-v="curiosa">curiosa</button>
          <button class="chip" data-grupo="estado" data-v="meio perdida">meio perdida</button>
        </div>
      </div>
      <div class="escreve">
        <textarea id="txt-chegada" placeholder="se quiser, conta com suas palavras... (opcional)"></textarea>
        <div class="hint">isso não vai a lugar nenhum público. é só entre você e o Koru.</div>
        <button class="btn" id="btn-sentindo" onclick="ir('ocupa')" disabled>Continuar</button>
      </div>
    </div>
  </section>

  <!-- CONVERSA 2: o que ocupa -->
  <section class="tela" id="ocupa" aria-label="O que ocupa sua mente">
    <div class="diag-head">
      <svg class="mini-logo" viewBox="0 0 60 60" aria-hidden="true"><path d="M30,8 C43,8 52,18 52,30 C52,39 46,46.5 37,49 C31,50.8 25,50 20.5,47" fill="none" stroke="#1C4A35" stroke-width="3" stroke-linecap="round"/><path d="M20.5,47 C15,43.5 12.5,37 14,31 C15.3,26 19.5,22.5 24,22.5" fill="none" stroke="#1C4A35" stroke-width="3" stroke-linecap="round"/><circle cx="28.5" cy="28" r="3" fill="#B8963E"/></svg>
      <div class="diag-passo">3 de 4</div>
    </div>
    <div class="prog"><div class="prog-fill" style="width:75%"></div></div>
    <div class="diag-corpo">
      <div class="chat">
        <div class="balao-eu" id="eco-chegada"></div>
        <div class="balao-koru" id="ponte-ocupa"></div>
        <div class="chips" role="group" aria-label="O que mais ocupa espaço">
          <button class="chip" data-grupo="ocupa" data-v="trabalho e carreira">trabalho e carreira</button>
          <button class="chip" data-grupo="ocupa" data-v="relação com meu corpo">relação com meu corpo</button>
          <button class="chip" data-grupo="ocupa" data-v="uma decisão que não sai da cabeça">uma decisão pendente</button>
          <button class="chip" data-grupo="ocupa" data-v="o sentido das coisas">o sentido das coisas</button>
          <button class="chip" data-grupo="ocupa" data-v="cansaço que não passa">cansaço que não passa</button>
        </div>
      </div>
      <div class="escreve">
        <button class="btn" id="btn-ocupa" onclick="ir('escolha')" disabled>Continuar</button>
      </div>
    </div>
  </section>

  <!-- CONVERSA 3: escolha -->
  <section class="tela" id="escolha" aria-label="O que você faz por escolha">
    <div class="diag-head">
      <svg class="mini-logo" viewBox="0 0 60 60" aria-hidden="true"><path d="M30,8 C43,8 52,18 52,30 C52,39 46,46.5 37,49 C31,50.8 25,50 20.5,47" fill="none" stroke="#1C4A35" stroke-width="3" stroke-linecap="round"/><path d="M20.5,47 C15,43.5 12.5,37 14,31 C15.3,26 19.5,22.5 24,22.5" fill="none" stroke="#1C4A35" stroke-width="3" stroke-linecap="round"/><circle cx="28.5" cy="28" r="3" fill="#B8963E"/></svg>
      <div class="diag-passo">4 de 4</div>
    </div>
    <div class="prog"><div class="prog-fill" style="width:95%"></div></div>
    <div class="diag-corpo">
      <div class="chat">
        <div class="balao-koru">Última — e a mais importante. O que na sua vida hoje você faz <em>por escolha de verdade</em>, e sente bem fazendo?</div>
      </div>
      <div class="escreve">
        <textarea id="txt-escolha" placeholder="pode ser pequeno. um ritual, um hobby, um momento..."></textarea>
        <div class="hint">é dessa resposta que nasce o primeiro fio do seu retrato.</div>
        <button class="btn" id="btn-escolha" onclick="gerar()" disabled>Ver meu retrato</button>
      </div>
    </div>
  </section>

  <!-- GERANDO -->
  <section class="tela" id="gerando" aria-label="Gerando retrato">
    <svg class="nucleo" viewBox="0 0 60 60" aria-hidden="true">
      <path d="M30,8 C43,8 52,18 52,30 C52,39 46,46.5 37,49 C31,50.8 25,50 20.5,47" fill="none" stroke="#1C4A35" stroke-width="2.2" stroke-linecap="round"/>
      <path d="M20.5,47 C15,43.5 12.5,37 14,31 C15.3,26 19.5,22.5 24,22.5" fill="none" stroke="#1C4A35" stroke-width="2.2" stroke-linecap="round"/>
      <path d="M24,22.5 C27,22.3 30,24.2 30.8,27.8 C31.5,30.8 29.4,33.6 26.6,33.6" fill="none" stroke="#1C4A35" stroke-width="2.2" stroke-linecap="round"/>
      <circle cx="28.5" cy="28" r="2.6" fill="#B8963E"/>
    </svg>
    <p class="gerando-txt serif" id="gerando-frase">Lendo o que você trouxe...</p>
  </section>

  <!-- RETRATO -->
  <section class="tela" id="retrato" aria-label="Seu retrato inicial">
    <div class="retrato-wrap">
      <div class="ret-eyebrow">quem você é agora · retrato inicial</div>
      <div class="ret-card">
        <p class="ret-texto serif" id="ret-texto"></p>
        <p class="ret-fonte" id="ret-fonte"></p>
      </div>
      <div class="ret-chips" id="ret-chips"></div>
      <p class="ret-aviso">Esse retrato é um começo, não um veredito — feito com o pouco que sei de você até aqui. Ele vai sendo reescrito conforme a gente conversa. E se algo soou errado, me corrige: sua palavra vale mais que minha leitura.</p>
      <button class="btn" onclick="entrarHome()">Começar a caminhar com o Koru</button>
    </div>
  </section>

  <!-- HOME -->
  <section class="tela" id="home" aria-label="Tela inicial — Hoje">
    <div class="home-head">
      <svg class="mini-logo" viewBox="0 0 60 60" aria-hidden="true" style="width:26px;height:26px"><path d="M30,8 C43,8 52,18 52,30 C52,39 46,46.5 37,49 C31,50.8 25,50 20.5,47" fill="none" stroke="#1C4A35" stroke-width="3" stroke-linecap="round"/><path d="M20.5,47 C15,43.5 12.5,37 14,31 C15.3,26 19.5,22.5 24,22.5" fill="none" stroke="#1C4A35" stroke-width="3" stroke-linecap="round"/><circle cx="28.5" cy="28" r="3" fill="#B8963E"/></svg>
      <div class="nome serif">Koru</div>
      <div class="home-dia" id="home-dia"></div>
    </div>
    <div class="home-chat" id="home-chat"></div>
    <div class="home-input">
      <input type="text" id="home-txt" placeholder="escreva ou fale com o Koru..." aria-label="Mensagem para o Koru">
      <button onclick="enviarHome()" aria-label="Enviar">➤</button>
    </div>
    <div class="tabs">
      <button class="tab on"><span>◉</span>Hoje</button>
      <button class="tab" onclick="alert('Padrões: disponível conforme o Koru te conhece — no protótipo, a partir do 3º dia de uso.')"><span>◈</span>Padrões</button>
      <button class="tab" onclick="alert('Você: seu retrato vivo e seus essenciais. No MVP completo, é reescrito a cada ciclo.')"><span>◎</span>Você</button>
    </div>
  </section>
</div>

<script>
const estado = { nome:"", chegada:"", chegadaTxt:"", ocupa:"", escolhaTxt:"" };

function ir(id){
  if (document.getElementById('sentindo').classList.contains('ativa')) {
    estado.chegadaTxt = document.getElementById('txt-chegada').value.trim();
  }
  document.querySelectorAll('.tela').forEach(t=>t.classList.remove('ativa'));
  document.getElementById(id).classList.add('ativa');
  if(id==='dados') setTimeout(()=>document.getElementById('f-nome').focus(),300);
  if(id==='ocupa') montarPonte();
  window.scrollTo(0,0);
}

/* chips: seleção única por grupo */
document.querySelectorAll('.chip').forEach(c=>{
  c.addEventListener('click',()=>{
    const g=c.dataset.grupo;
    document.querySelectorAll(`.chip[data-grupo="${g}"]`).forEach(x=>x.classList.remove('on'));
    c.classList.add('on');
    estado[g==='estado'?'chegada':'ocupa']=c.dataset.v;
    if(g==='estado') document.getElementById('btn-sentindo').disabled=false;
    if(g==='ocupa') document.getElementById('btn-ocupa').disabled=false;
  });
});
document.getElementById('txt-escolha').addEventListener('input',e=>{
  document.getElementById('btn-escolha').disabled = e.target.value.trim().length<3;
});

function montarPonte(){
  const eco = estado.chegadaTxt ? `"${estado.chegadaTxt}"` : `Estou me sentindo ${estado.chegada}.`;
  document.getElementById('eco-chegada').textContent = eco;
  const pontes = {
    "em transição":"Transição é uma palavra que carrega muita coisa. E enquanto ela acontece — o que mais ocupa espaço na sua cabeça num dia comum?",
    "sobrecarregada":"Obrigado por dizer isso sem rodeios. Quando a sobrecarga aperta — o que mais ocupa espaço na sua cabeça?",
    "cansada mas esperançosa":"Cansaço com esperança é um lugar de força, mesmo que não pareça. O que mais ocupa espaço na sua cabeça num dia comum?",
    "curiosa":"Curiosidade é o melhor jeito de chegar. Me conta — o que mais ocupa espaço na sua cabeça num dia comum?",
    "meio perdida":"Chegar meio perdida já é chegar — e isso conta. O que mais ocupa espaço na sua cabeça num dia comum?"
  };
  document.getElementById('ponte-ocupa').textContent = pontes[estado.chegada] || pontes["curiosa"];
}

function gerar(){
  estado.escolhaTxt = document.getElementById('txt-escolha').value.trim();
  estado.nome = document.getElementById('f-nome').value.trim() || "você";
  ir('gerando');
  const frases=["Lendo o que você trouxe...","Separando o que é ruído do que é seu...","Escrevendo seu primeiro espelho..."];
  let i=0;
  const el=document.getElementById('gerando-frase');
  const tick=setInterval(()=>{ i++; if(i<frases.length){el.textContent=frases[i];} else {clearInterval(tick); montarRetrato(); ir('retrato');} },1400);
}

function montarRetrato(){
  const nome = estado.nome==="você" ? "Você" : estado.nome.charAt(0).toUpperCase()+estado.nome.slice(1);
  const mapaEstado={
    "em transição":"chega num momento de travessia — saindo de algo que já não cabe, ainda desenhando o que vem",
    "sobrecarregada":"chega carregando mais do que devia — e o primeiro movimento aqui não é fazer mais, é soltar",
    "cansada mas esperançosa":"chega cansada, mas com a esperança intacta — e isso diz mais sobre você do que o cansaço",
    "curiosa":"chega com curiosidade — a porta mais honesta para se conhecer",
    "meio perdida":"chega sem mapa — e admitir isso já é o primeiro ponto no mapa"
  };
  const mapaOcupa={
    "trabalho e carreira":"O trabalho ocupa o centro do palco da sua mente agora",
    "relação com meu corpo":"A relação com o próprio corpo é o tema que pede atenção",
    "uma decisão que não sai da cabeça":"Existe uma decisão rondando seus pensamentos — nomeá-la já reduz o peso",
    "o sentido das coisas":"A pergunta pelo sentido está viva em você — sinal de profundidade, não de crise",
    "cansaço que não passa":"Um cansaço que não passa costuma ser mensagem, não fraqueza"
  };
  const escolha = estado.escolhaTxt ? `E quando você diz que escolhe <span class="voce-disse">"${estado.escolhaTxt}"</span> — aí mora seu primeiro fio: um lugar onde você já é inteira por vontade própria. É por ele que a gente começa.` : "Ainda não sei o que você faz por escolha plena — e essa vai ser nossa primeira descoberta juntas.";
  document.getElementById('ret-texto').innerHTML =
    `${nome} ${mapaEstado[estado.chegada]||mapaEstado["curiosa"]}. ${mapaOcupa[estado.ocupa]||""}. ${escolha}`;
  document.getElementById('ret-fonte').textContent =
    "baseado nas suas 3 respostas de hoje — evidência pequena, leitura provisória";
  const chips=[estado.chegada, estado.ocupa, "primeiro fio identificado"].filter(Boolean);
  document.getElementById('ret-chips').innerHTML = chips.map(c=>`<span class="ret-chip">${c}</span>`).join("");
}

function entrarHome(){
  ir('home');
  const dias=["dom","seg","ter","qua","qui","sex","sáb"];
  const meses=["jan","fev","mar","abr","mai","jun","jul","ago","set","out","nov","dez"];
  const d=new Date();
  document.getElementById('home-dia').textContent=`${dias[d.getDay()]}, ${d.getDate()} ${meses[d.getMonth()]}`;
  const chat=document.getElementById('home-chat');
  chat.innerHTML="";
  const nome = estado.nome==="você" ? "" : `, ${estado.nome.charAt(0).toUpperCase()+estado.nome.slice(1)}`;
  addKoru(chat, `Seu retrato está guardado${nome} — e vai crescer com a gente. Amanhã eu te faço a primeira pergunta do dia. Por agora, só uma coisa:`);
  setTimeout(()=>{
    const protoTemas={
      "cansaço que não passa":["Preparação pro sono","10 minutos · áudio guiado","Pra noites em que a mente segue no modo dia: alongamento suave, respiração 4-7-8 e escaneamento corporal.","☾"],
      "sobrecarregada":["Esvaziamento mental","7 minutos · escrita guiada","Tirar da cabeça o que está ocupando espaço: despejar, separar, soltar.","☁"],
      "uma decisão que não sai da cabeça":["Esvaziamento mental","7 minutos · escrita guiada","Colocar a decisão no papel guiado — agir, soltar ou adiar. Nomear já alivia.","☁"]
    };
    const p=protoTemas[estado.ocupa]||["Âncora de foco","3 minutos · respiração e intenção","Um começo pequeno: uma respiração guiada e uma pergunta — o que importa nas próximas 2 horas?","◦"];
    const card=document.createElement('div');
    card.className='proto-card';
    card.innerHTML=`<div class="proto-top"><div class="proto-ic">${p[3]}</div><div><div class="proto-nome serif">${p[0]}</div><div class="proto-tempo">${p[1]}</div></div></div>
      <div class="proto-desc">${p[2]}</div>
      <div class="proto-acoes"><button class="proto-btn cheio" onclick="alert('No MVP completo: modo imersivo com áudio guiado. O protótipo termina aqui — e a conversa continua amanhã.')">Começar agora</button>
      <button class="proto-btn vazio" onclick="alert('Sempre uma alternativa legítima: a conversa continua sem o protocolo. O Koru nunca força a ação.')">Agora não</button></div>`;
    chat.appendChild(card);
    chat.scrollTop=chat.scrollHeight;
  },900);
}

function addKoru(chat,txt){
  const b=document.createElement('div');b.className='balao-koru';b.textContent=txt;chat.appendChild(b);
  chat.scrollTop=chat.scrollHeight;
}
function enviarHome(){
  const inp=document.getElementById('home-txt');
  const v=inp.value.trim(); if(!v)return;
  const chat=document.getElementById('home-chat');
  const b=document.createElement('div');b.className='balao-eu';b.textContent=v;chat.appendChild(b);
  inp.value="";
  const t=document.createElement('div');t.className='balao-koru';t.innerHTML='<span class="typing"><i></i><i></i><i></i></span>';
  chat.appendChild(t);chat.scrollTop=chat.scrollHeight;
  setTimeout(()=>{t.textContent="No MVP completo, é aqui que o cérebro do Koru responde — com o seu contexto, seu histórico e seu tom. No protótipo, essa conversa é encenada: o que importa testar é se você sentiria vontade de responder.";chat.scrollTop=chat.scrollHeight;},1200);
}
document.getElementById('home-txt').addEventListener('keydown',e=>{if(e.key==='Enter')enviarHome()});
</script>
</body>
